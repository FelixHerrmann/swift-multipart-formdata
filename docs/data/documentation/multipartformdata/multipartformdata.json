{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"MultipartFormData"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multipart form data is an encoding format devised as a means of encoding an HTTP form for posting up to a server."},{"type":"text","text":" "},{"type":"text","text":"For more informations and a detailed description see "},{"type":"reference","isActive":true,"identifier":"https:\/\/datatracker.ietf.org\/doc\/html\/rfc7578"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are two ways to create a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MultipartFormData\/documentation\/MultipartFormData"},{"type":"text","text":":"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"manually with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MultipartFormData\/documentation\/MultipartFormData\/MultipartFormData\/init(boundary:body:)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"via result builder with "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MultipartFormData\/documentation\/MultipartFormData\/MultipartFormData\/init(boundary:builder:)"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MultipartFormData\/documentation\/MultipartFormData\/MultipartFormData\/boundary"},{"type":"text","text":" can be created manually but using a randomly generated one is fine in most situations."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a request from "},{"type":"reference","isActive":true,"identifier":"doc:\/\/MultipartF